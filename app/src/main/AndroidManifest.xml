<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to read and change audio stream volumes -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_volume_on"
        android:theme="@style/Theme.VolumeTile">

        <!--
            Quick Settings Tile Service.
            - android:exported="true"  : the system must be able to bind this service.
            - android:permission       : restricts binding to the system only.
            - META_DATA_ACTIVE_TILE    : the tile manages its own state (STATE_ACTIVE/INACTIVE).
        -->
        <service
            android:name=".VolumeTileService"
            android:exported="true"
            android:label="@string/tile_label"
            android:icon="@drawable/ic_volume_on"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

        <!--
            Activity launched when the user long-presses the tile (ACTION_QS_TILE_PREFERENCES).
            On tap it shows the system volume popup; on long-press it opens Sound settings.
        -->
        <activity
            android:name=".VolumeSettingsActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
            </intent-filter>
        </activity>

    </application>

</manifest>
