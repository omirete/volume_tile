<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tile_label"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:layout_marginBottom="24dp" />

        <!-- ── Media ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_stream_media"
                android:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stream_media"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvMediaLevel"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textAppearance="?attr/textAppearanceLabelMedium" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Ring ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_stream_ring"
                android:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stream_ring"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvRingLevel"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textAppearance="?attr/textAppearanceLabelMedium" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderRing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Alarm ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_stream_alarm"
                android:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stream_alarm"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvAlarmLevel"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textAppearance="?attr/textAppearanceLabelMedium" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ── Notification ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_stream_notification"
                android:tint="?attr/colorOnSurfaceVariant"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stream_notification"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:paddingStart="10dp" />

            <TextView
                android:id="@+id/tvNotificationLevel"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="0"
                android:textAppearance="?attr/textAppearanceLabelMedium" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
